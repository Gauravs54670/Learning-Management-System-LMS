{
  "info": {
    "name": "Learning Management System (LMS)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/lms3",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/public/register-user", "host": ["{{baseUrl}}"], "path": ["public", "register-user"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gaurav@example.com\",\n  \"fullName\": \"Gaurav Singh\",\n  \"password\": \"password123\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Verify User (Forgot Password Request)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/public/verify-user?email=gaurav@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["public", "verify-user"],
              "query": [{"key": "email", "value": "gaurav@example.com"}]
            }
          }
        },
        {
          "name": "Forgot Password Change",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/public/forgot-password-change?email=gaurav@example.com&otp=1234&new password=newpass123",
              "host": ["{{baseUrl}}"],
              "path": ["public", "forgot-password-change"],
              "query": [
                {"key": "email", "value": "gaurav@example.com"},
                {"key": "otp", "value": "1234"},
                {"key": "new password", "value": "newpass123"}
              ]
            }
          }
        },
        {
          "name": "Get All Published Courses",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/public/all-published-courses", "host": ["{{baseUrl}}"], "path": ["public", "all-published-courses"]}
          }
        },
        {
          "name": "Get Public Course by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/public/get-public-course/1", "host": ["{{baseUrl}}"], "path": ["public", "get-public-course", "1"]}
          }
        },
        {
          "name": "Search Courses by Keyword",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/public/get-public-courses?keyword=spring boot",
              "host": ["{{baseUrl}}"],
              "path": ["public", "get-public-courses"],
              "query": [{"key": "keyword", "value": "spring boot"}]
            }
          }
        },
        {
          "name": "Get Courses by Category",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/public/get-courses-category?category=PROGRAMMING",
              "host": ["{{baseUrl}}"],
              "path": ["public", "get-courses-category"],
              "query": [{"key": "category", "value": "PROGRAMMING"}]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Verify Account for Password Change",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/user/password-change-request/verify-account?old password=password123",
              "host": ["{{baseUrl}}"],
              "path": ["user", "password-change-request", "verify-account"],
              "query": [{"key": "old password", "value": "password123"}]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/user/password-change?otp=1234&new password=newpass123",
              "host": ["{{baseUrl}}"],
              "path": ["user", "password-change"],
              "query": [
                {"key": "otp", "value": "1234"},
                {"key": "new password", "value": "newpass123"}
              ]
            }
          }
        },
        {
          "name": "Get Account Status",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/user/account-status", "host": ["{{baseUrl}}"], "path": ["user", "account-status"]}
          }
        },
        {
          "name": "Get My Roles",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/user/get-roles", "host": ["{{baseUrl}}"], "path": ["user", "get-roles"]}
          }
        }
      ]
    },
    {
      "name": "Learner (Student)",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/learner/get-myProfile", "host": ["{{baseUrl}}"], "path": ["learner", "get-myProfile"]}
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/learner/update-profile", "host": ["{{baseUrl}}"], "path": ["learner", "update-profile"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Gaurav Kumar\",\n  \"bio\": \"Java developer\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Update Account Status",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/learner/update-status?status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["learner", "update-status"],
              "query": [{"key": "status", "value": "ACTIVE"}]
            }
          }
        },
        {
          "name": "Switch Profile to Instructor",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/learner/switch-profile", "host": ["{{baseUrl}}"], "path": ["learner", "switch-profile"]}
          }
        },
        {
          "name": "Add Course Review",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/learner/addReview-Course/1", "host": ["{{baseUrl}}"], "path": ["learner", "addReview-Course", "1"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent course!\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Delete Course Review",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/learner/deleteReview-Course/1", "host": ["{{baseUrl}}"], "path": ["learner", "deleteReview-Course", "1"]}
          }
        },
        {
          "name": "Get Course Content",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/learner/get-course/1", "host": ["{{baseUrl}}"], "path": ["learner", "get-course", "1"]}
          }
        },
        {
          "name": "Get Course Media",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/learner/get-courseMedia/1/1", "host": ["{{baseUrl}}"], "path": ["learner", "get-courseMedia", "1", "1"]}
          }
        },
        {
          "name": "Update Media Progress",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/learner/update-media-progress/1", "host": ["{{baseUrl}}"], "path": ["learner", "update-media-progress", "1"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mediaId\": 1,\n  \"watchedDuration\": 120,\n  \"totalDuration\": 300\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        }
      ]
    },
    {
      "name": "Instructor",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-myProfile", "host": ["{{baseUrl}}"], "path": ["instructor", "get-myProfile"]}
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/instructor/update-profile", "host": ["{{baseUrl}}"], "path": ["instructor", "update-profile"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Senior Java Developer\",\n  \"expertise\": \"Spring Boot\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Get Course Stats Dashboard",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-stats", "host": ["{{baseUrl}}"], "path": ["instructor", "get-stats"]}
          }
        },
        {
          "name": "Get Published Courses",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-published-courses", "host": ["{{baseUrl}}"], "path": ["instructor", "get-published-courses"]}
          }
        },
        {
          "name": "Get Draft Courses",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-draft-courses", "host": ["{{baseUrl}}"], "path": ["instructor", "get-draft-courses"]}
          }
        },
        {
          "name": "Get Discontinued Courses",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-discontinued-courses", "host": ["{{baseUrl}}"], "path": ["instructor", "get-discontinued-courses"]}
          }
        },
        {
          "name": "Publish Course",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/publish-course/1", "host": ["{{baseUrl}}"], "path": ["instructor", "publish-course", "1"]}
          }
        },
        {
          "name": "Draft Course",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/draft-course/1", "host": ["{{baseUrl}}"], "path": ["instructor", "draft-course", "1"]}
          }
        },
        {
          "name": "Discontinue Course",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/discontinue-course/1", "host": ["{{baseUrl}}"], "path": ["instructor", "discontinue-course", "1"]}
          }
        },
        {
          "name": "Get All Course Reviews",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-allCourse-Reviews", "host": ["{{baseUrl}}"], "path": ["instructor", "get-allCourse-Reviews"]}
          }
        },
        {
          "name": "Get Reviews of Specific Course",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-course-reviews/1", "host": ["{{baseUrl}}"], "path": ["instructor", "get-course-reviews", "1"]}
          }
        },
        {
          "name": "Get My Reviews",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/instructor/get-myReviews", "host": ["{{baseUrl}}"], "path": ["instructor", "get-myReviews"]}
          }
        }
      ]
    },
    {
      "name": "Course",
      "item": [
        {
          "name": "Register Course",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/course/register-course", "host": ["{{baseUrl}}"], "path": ["course", "register-course"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseTitle\": \"Spring Boot Masterclass\",\n  \"courseDescription\": \"Learn Spring Boot from scratch\",\n  \"courseCategory\": \"PROGRAMMING\",\n  \"coursePrice\": 999.00\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Upload Course Media",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/course/upload-media/1?mediaType=VIDEO",
              "host": ["{{baseUrl}}"],
              "path": ["course", "upload-media", "1"],
              "query": [{"key": "mediaType", "value": "VIDEO"}]
            },
            "body": {
              "mode": "formdata",
              "formdata": [{"key": "media", "type": "file", "src": ""}]
            }
          }
        },
        {
          "name": "Get Media Preview",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/course/media-preview/1?mediaType=VIDEO",
              "host": ["{{baseUrl}}"],
              "path": ["course", "media-preview", "1"],
              "query": [{"key": "mediaType", "value": "VIDEO"}]
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/course/update-course/1", "host": ["{{baseUrl}}"], "path": ["course", "update-course", "1"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseTitle\": \"Spring Boot Advanced\",\n  \"courseDescription\": \"Advanced Spring Boot concepts\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Change Course Availability",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/course/change-availability/1?choice=true",
              "host": ["{{baseUrl}}"],
              "path": ["course", "change-availability", "1"],
              "query": [{"key": "choice", "value": "true"}]
            }
          }
        },
        {
          "name": "Get Course by Instructor",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/course/get-course/1", "host": ["{{baseUrl}}"], "path": ["course", "get-course", "1"]}
          }
        },
        {
          "name": "Delete Course Media",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/course/delete-media/1", "host": ["{{baseUrl}}"], "path": ["course", "delete-media", "1"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mediaId\": 1,\n  \"mediaType\": \"VIDEO\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Get All Course Medias",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/course/get-course-medias/1", "host": ["{{baseUrl}}"], "path": ["course", "get-course-medias", "1"]}
          }
        },
        {
          "name": "Mark Media Check",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/course/mark-check/1/1?check=true",
              "host": ["{{baseUrl}}"],
              "path": ["course", "mark-check", "1", "1"],
              "query": [{"key": "check", "value": "true"}]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollment",
      "item": [
        {
          "name": "Enroll in Course",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/enrollment/enroll/1", "host": ["{{baseUrl}}"], "path": ["enrollment", "enroll", "1"]}
          }
        },
        {
          "name": "Is Enrolled in Course",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/enrollment/isEnrolled/1", "host": ["{{baseUrl}}"], "path": ["enrollment", "isEnrolled", "1"]}
          }
        },
        {
          "name": "Get My Enrollments",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/enrollment/myEnrollments", "host": ["{{baseUrl}}"], "path": ["enrollment", "myEnrollments"]}
          }
        },
        {
          "name": "Cancel Enrollment",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/enrollment/cancel-enrollment/1", "host": ["{{baseUrl}}"], "path": ["enrollment", "cancel-enrollment", "1"]}
          }
        }
      ]
    }
  ]
}